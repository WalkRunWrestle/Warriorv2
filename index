  <script>
    const LOGIN_CODE = "WRW26";
    const TARGET_KM = 21;
    const STORAGE_KEY = "wrw_warrior_v1_sessions";
    const COMPLETE_KEY = "wrw_warrior_v1_complete";
    const STEPS_PER_KM = 1312;
    const MIN_ACCURACY_METERS = 40;
    const MIN_MOVEMENT_METERS = 8;
    const MAX_JUMP_METERS = 250;
    const WRW_EMAIL = "Log@walkrunwrestle.com";

    let map;
    let userMarker;
    let routeLine;
    let watchId = null;
    let isTracking = false;
    let startTime = null;
    let timerInterval = null;
    let currentDistanceMeters = 0;
    let lastPosition = null;
    let routePoints = [];
    let wakeLock = null;

    const loginScreen = document.getElementById("loginScreen");
    const appScreen = document.getElementById("appScreen");
    const loginCodeInput = document.getElementById("loginCode");
    const loginBtn = document.getElementById("loginBtn");

    const startBtn = document.getElementById("startBtn");
    const endBtn = document.getElementById("endBtn");
    const resetBtn = document.getElementById("resetBtn");
    const logoutBtn = document.getElementById("logoutBtn");

    const manualDistanceInput = document.getElementById("manualDistance");
    const manualDateInput = document.getElementById("manualDate");
    const manualAddBtn = document.getElementById("manualAddBtn");

    const liveDistanceEl = document.getElementById("liveDistance");
    const liveTimeEl = document.getElementById("liveTime");
    const liveStepsEl = document.getElementById("liveSteps");
    const savedTotalKmEl = document.getElementById("savedTotalKm");
    const progressFillEl = document.getElementById("progressFill");
    const sessionListEl = document.getElementById("sessionList");
    const trackingNotice = document.getElementById("trackingNotice");
    const statusBar = document.getElementById("statusBar");
    const runsSavedCount = document.getElementById("runsSavedCount");
    const lastSavedRun = document.getElementById("lastSavedRun");
    const gpsReadyBox = document.getElementById("gpsReadyBox");

    const locationOverlay = document.getElementById("locationOverlay");
    const enableLocationBtn = document.getElementById("enableLocationBtn");
    const locationStatus = document.getElementById("locationStatus");

    const finishOverlay = document.getElementById("finishOverlay");
    const finishTotalEl = document.getElementById("finishTotal");
    const finishStepsEl = document.getElementById("finishSteps");
    const finishMessage = document.getElementById("finishMessage");
    const proofBtn = document.getElementById("proofBtn");
    const closeFinishBtn = document.getElementById("closeFinishBtn");
    const proofRunSelect = document.getElementById("proofRunSelect");
    const downloadSelectedProofBtn = document.getElementById("downloadSelectedProofBtn");
    const downloadAllProofsBtn = document.getElementById("downloadAllProofsBtn");
    const completionActions = document.getElementById("completionActions");
    const viewCompletionBtn = document.getElementById("viewCompletionBtn");

    const manualToggle = document.getElementById("manualToggle");
    const manualContent = document.getElementById("manualContent");
    const manualToggleText = document.getElementById("manualToggleText");

    const savedRunsToggle = document.getElementById("savedRunsToggle");
    const savedRunsContent = document.getElementById("savedRunsContent");
    const savedRunsToggleText = document.getElementById("savedRunsToggleText");

    const howItWorksBtn = document.getElementById("howItWorksBtn");
    const howItWorksOverlay = document.getElementById("howItWorksOverlay");
    const closeHowItWorksBtn = document.getElementById("closeHowItWorksBtn");

    const sendProofHelpToggle = document.getElementById("sendProofHelpToggle");
    const sendProofHelpToggleText = document.getElementById("sendProofHelpToggleText");
    const sendProofHelpContent = document.getElementById("sendProofHelpContent");

    function formatTime(ms){
      const totalSeconds = Math.floor(ms / 1000);
      const hours = String(Math.floor(totalSeconds / 3600)).padStart(2, "0");
      const mins = String(Math.floor((totalSeconds % 3600) / 60)).padStart(2, "0");
      const secs = String(totalSeconds % 60).padStart(2, "0");
      return `${hours}:${mins}:${secs}`;
    }

    function estimateStepsFromKm(km){
      return Math.round(km * STEPS_PER_KM);
    }

    function getSessions(){
      return JSON.parse(localStorage.getItem(STORAGE_KEY) || "[]");
    }

    function saveSessions(sessions){
      localStorage.setItem(STORAGE_KEY, JSON.stringify(sessions));
    }

    function getTotalKm(){
      return getSessions().reduce((sum, session) => sum + (session.distanceKm || 0), 0);
    }

    function getTotalSteps(){
      return getSessions().reduce((sum, session) => sum + (session.steps || 0), 0);
    }

    function hasManualRuns(){
      return getSessions().some(session => session.method === "Manual");
    }

    function setStatus(text, className){
      statusBar.textContent = text;
      statusBar.className = `status-bar ${className}`;
    }

    function updateFinishMessage(){
      if (hasManualRuns()){
        finishMessage.innerHTML = `
          <strong>This completion includes one or more manual runs.</strong><br><br>
          Manual runs need additional supporting proof.<br>
          GPS runs can use their downloaded proof images.
        `;
      } else {
        finishMessage.innerHTML = `
          <strong>Your GPS runs have downloadable proof images.</strong><br><br>
          Please download and attach them before sending your email.
        `;
      }
    }

    function populateProofRunSelect(){
      const sessions = getSessions();
      proofRunSelect.innerHTML = `<option value="">Select a saved run</option>`;

      sessions.forEach((session, index) => {
        const option = document.createElement("option");
        option.value = index;
        option.textContent = `Run ${index + 1} - ${session.distanceKm.toFixed(2)} km - ${session.method}`;
        proofRunSelect.appendChild(option);
      });
    }

    function updateTopSummary(){
      const sessions = getSessions();
      runsSavedCount.textContent = `${sessions.length} ${sessions.length === 1 ? "run" : "runs"}`;

      if (!sessions.length){
        lastSavedRun.textContent = "No runs saved yet";
        return;
      }

      const last = sessions[sessions.length - 1];
      const method = last.method === "GPS" ? "GPS" : "Manual";
      const dateText = new Date(last.date).toLocaleDateString();
      lastSavedRun.textContent = `${last.distanceKm.toFixed(2)} km · ${method} · ${dateText}`;
    }

    function updateOverallProgress(){
      const totalKm = getTotalKm();
      savedTotalKmEl.textContent = totalKm.toFixed(2);

      const pct = Math.min((totalKm / TARGET_KM) * 100, 100);
      progressFillEl.style.width = pct + "%";

      finishTotalEl.textContent = totalKm.toFixed(2);
      finishStepsEl.textContent = getTotalSteps().toLocaleString();
      updateFinishMessage();
      updateTopSummary();

      if (totalKm >= TARGET_KM){
        completionActions.style.display = "flex";
        if (!isTracking) setStatus("21K complete", "status-complete");

        const alreadyComplete = localStorage.getItem(COMPLETE_KEY) === "true";
        if (!alreadyComplete){
          localStorage.setItem(COMPLETE_KEY, "true");
          showFinishPopup();
        }
      } else {
        completionActions.style.display = "none";
        if (!isTracking) setStatus("Ready to track", "status-ready");
      }
    }

    function renderSessions(){
      const sessions = getSessions();

      if (!sessions.length){
        sessionListEl.innerHTML = `
          <div class="session-item">
            <div class="session-meta">No runs saved yet.</div>
          </div>
        `;
        return;
      }

      const reversed = sessions.slice().reverse();

      sessionListEl.innerHTML = reversed.map((session, reversedIndex) => {
        const realIndex = sessions.length - 1 - reversedIndex;
        const badgeClass = session.method === "Manual" ? "badge-manual" : "badge-gps";
        const badgeText = session.method === "Manual" ? "Manual entry - extra proof needed" : "GPS tracked run";
        const proofBadge = session.proofDownloaded ? `<span class="session-badge badge-proof">Proof ready</span>` : "";

        return `
          <div class="session-item">
            <div class="session-top">
              <span>Run ${sessions.length - reversedIndex}</span>
              <span>${session.distanceKm.toFixed(2)} km</span>
            </div>

            <div class="session-badge ${badgeClass}">${badgeText}</div>
            ${proofBadge}

            <div class="session-meta">
              ${session.method === "GPS" ? `Time: ${session.timeText}<br>` : ``}
              Estimated steps: ${session.steps.toLocaleString()}<br>
              Method: ${session.method}<br>
              Date: ${new Date(session.date).toLocaleDateString()}
            </div>

            <div class="session-actions">
              <button class="btn btn-secondary" onclick="downloadProofForRun(${realIndex})">Download Proof</button>
            </div>
          </div>
        `;
      }).join("");
    }

    function showFinishPopup(){
      populateProofRunSelect();
      finishOverlay.classList.add("show");
    }

    function hideFinishPopup(){
      finishOverlay.classList.remove("show");
    }

    function resetLiveStats(){
      liveDistanceEl.textContent = "0.00";
      liveTimeEl.textContent = "00:00:00";
      liveStepsEl.textContent = "0";
    }

    function initMap(){
      if (map) return;

      map = L.map("map").setView([51.505, -0.09], 13);

      L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        maxZoom: 19,
        attribution: "&copy; OpenStreetMap contributors"
      }).addTo(map);

      routeLine = L.polyline([], {
        color: "#4fd1d1",
        weight: 5,
        opacity: 0.95
      }).addTo(map);
    }

    async function requestWakeLock(){
      try{
        if ("wakeLock" in navigator && document.visibilityState === "visible"){
          wakeLock = await navigator.wakeLock.request("screen");
        }
      } catch (err){
        console.error("Wake lock failed:", err);
      }
    }

    async function releaseWakeLock(){
      try{
        if (wakeLock){
          await wakeLock.release();
          wakeLock = null;
        }
      } catch (err){
        console.error("Wake lock release failed:", err);
      }
    }

    function haversineMeters(lat1, lon1, lat2, lon2){
      const R = 6371000;
      const toRad = d => d * Math.PI / 180;
      const dLat = toRad(lat2 - lat1);
      const dLon = toRad(lon2 - lon1);

      const a =
        Math.sin(dLat / 2) * Math.sin(dLat / 2) +
        Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) *
        Math.sin(dLon / 2) * Math.sin(dLon / 2);

      const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
      return R * c;
    }

    function startTimer(){
      timerInterval = setInterval(() => {
        if (!startTime) return;
        const elapsed = Date.now() - startTime;
        liveTimeEl.textContent = formatTime(elapsed);
      }, 1000);
    }

    function stopTimer(){
      clearInterval(timerInterval);
      timerInterval = null;
    }

    function toggleSection(contentEl, labelEl){
      const open = contentEl.classList.contains("open");
      contentEl.classList.toggle("open", !open);
      labelEl.textContent = open ? "Show" : "Hide";
    }

    function enableLocationFromPopup(){
      if (!navigator.geolocation){
        locationStatus.textContent = "This browser does not support location.";
        return;
      }

      locationStatus.textContent = "Checking permission...";

      navigator.geolocation.getCurrentPosition(
        (position) => {
          initMap();

          const point = [position.coords.latitude, position.coords.longitude];

          if (!userMarker){
            userMarker = L.marker(point).addTo(map);
          } else {
            userMarker.setLatLng(point);
          }

          map.setView(point, 17);

          locationStatus.textContent = "Location enabled ✔";
          startBtn.disabled = false;
          setStatus("Ready to track", "status-ready");

          setTimeout(() => {
            locationOverlay.classList.remove("show");
          }, 500);
        },
        (error) => {
          console.error(error);
          locationStatus.textContent = "Location blocked. Please allow it in your browser or phone settings.";
        },
        {
          enableHighAccuracy: true,
          maximumAge: 0,
          timeout: 10000
        }
      );
    }

    async function startRun(){
      if (!navigator.geolocation){
        alert("Your browser does not support location tracking.");
        return;
      }

      initMap();

      isTracking = true;
      startTime = Date.now();
      currentDistanceMeters = 0;
      lastPosition = null;
      routePoints = [];
      routeLine.setLatLngs([]);
      resetLiveStats();

      startBtn.disabled = true;
      endBtn.disabled = false;
      manualAddBtn.disabled = true;

      setStatus("Tracking in progress", "status-live");
      gpsReadyBox.innerHTML = `GPS live. Most devices will keep tracking in the background.`;
      trackingNotice.innerHTML = `Tracking usually continues in the background on most devices.<br>If you leave the app or lock your phone, just double-check your distance when you return.<br><br><strong>Screen wake lock is active where supported.</strong>`;

      startTimer();
      await requestWakeLock();

      watchId = navigator.geolocation.watchPosition(
        handlePosition,
        handleLocationError,
        {
          enableHighAccuracy: true,
          maximumAge: 0,
          timeout: 10000
        }
      );
    }

    function handlePosition(position){
      if (!isTracking) return;

      const { latitude, longitude, accuracy } = position.coords;

      if (accuracy > MIN_ACCURACY_METERS) return;

      const point = [latitude, longitude];

      if (!lastPosition){
        lastPosition = point;
        routePoints.push(point);

        if (!userMarker){
          userMarker = L.marker(point).addTo(map);
        } else {
          userMarker.setLatLng(point);
        }

        routeLine.setLatLngs(routePoints);
        map.setView(point, 17);
        return;
      }

      const segmentMeters = haversineMeters(
        lastPosition[0],
        lastPosition[1],
        latitude,
        longitude
      );

      if (segmentMeters < MIN_MOVEMENT_METERS) return;
      if (segmentMeters > MAX_JUMP_METERS) return;

      currentDistanceMeters += segmentMeters;
      lastPosition = point;
      routePoints.push(point);

      userMarker.setLatLng(point);
      routeLine.setLatLngs(routePoints);
      map.panTo(point);

      const km = currentDistanceMeters / 1000;
      liveDistanceEl.textContent = km.toFixed(2);
      liveStepsEl.textContent = estimateStepsFromKm(km).toLocaleString();
    }

    function handleLocationError(error){
      console.error(error);
      stopRunTrackingOnly();
      startBtn.disabled = false;
      endBtn.disabled = true;
      manualAddBtn.disabled = false;
      trackingNotice.textContent = "Tracking stopped. You can try again or use Manual Entry.";
      gpsReadyBox.textContent = "GPS ready. Most devices will keep tracking in the background.";
      setStatus("Ready to track", "status-ready");
      alert("Location tracking failed. You can try again or use Manual Entry.");
    }

    function stopRunTrackingOnly(){
      isTracking = false;

      if (watchId !== null){
        navigator.geolocation.clearWatch(watchId);
        watchId = null;
      }

      stopTimer();
      releaseWakeLock();
    }

    function endRun(){
      if (!isTracking) return;

      stopRunTrackingOnly();

      const elapsedMs = Date.now() - startTime;
      const distanceKm = currentDistanceMeters / 1000;
      const steps = estimateStepsFromKm(distanceKm);

      startBtn.disabled = false;
      endBtn.disabled = true;
      manualAddBtn.disabled = false;
      trackingNotice.textContent = "Tracking usually continues in the background on most devices. If you leave the app or lock your phone, just double-check your distance when you return.";
      gpsReadyBox.textContent = "GPS ready. Most devices will keep tracking in the background.";

      if (distanceKm <= 0){
        setStatus("Ready to track", "status-ready");
        alert("No distance was recorded for this run.");
        return;
      }

      const sessions = getSessions();
      sessions.push({
        date: new Date().toISOString(),
        distanceKm,
        timeMs: elapsedMs,
        timeText: formatTime(elapsedMs),
        steps,
        method: "GPS",
        routePoints: routePoints.slice(),
        proofDownloaded: false
      });
      saveSessions(sessions);

      renderSessions();
      updateOverallProgress();
      resetLiveStats();

      setStatus("Run saved", "status-saved");

      currentDistanceMeters = 0;
      startTime = null;
      lastPosition = null;
      routePoints = [];
      if (routeLine) routeLine.setLatLngs([]);
    }

    function addManualRun(){
      if (isTracking){
        alert("End the current GPS run before adding a manual run.");
        return;
      }

      const distanceKm = Number(manualDistanceInput.value);
      const selectedDate = manualDateInput.value;

      if (!distanceKm || distanceKm <= 0){
        alert("Enter a valid manual distance.");
        return;
      }

      if (!selectedDate){
        alert("Select a date for the manual run.");
        return;
      }

      const steps = estimateStepsFromKm(distanceKm);

      const sessions = getSessions();
      sessions.push({
        date: new Date(selectedDate + "T12:00:00").toISOString(),
        distanceKm,
        timeMs: 0,
        timeText: "Manual entry",
        steps,
        method: "Manual",
        routePoints: [],
        proofDownloaded: false
      });
      saveSessions(sessions);

      manualDistanceInput.value = "";
      manualDateInput.value = "";

      renderSessions();
      updateOverallProgress();
      setStatus("Manual entry added", "status-saved");

      alert("Manual run saved. Additional proof will be needed for this entry.");
    }

    function downloadProofForRun(index){
      const sessions = getSessions();
      const session = sessions[index];
      if (!session) return;

      const canvas = document.createElement("canvas");
      const width = 1200;
      const height = 1600;
      canvas.width = width;
      canvas.height = height;
      const ctx = canvas.getContext("2d");

      const bg = ctx.createLinearGradient(0, 0, 0, height);
      bg.addColorStop(0, "#0b0b0d");
      bg.addColorStop(1, "#060608");
      ctx.fillStyle = bg;
      ctx.fillRect(0, 0, width, height);

      const glow = ctx.createRadialGradient(width * 0.2, height * 0.15, 0, width * 0.2, height * 0.15, 500);
      glow.addColorStop(0, "rgba(79,209,209,0.16)");
      glow.addColorStop(.5, "rgba(255,0,229,0.10)");
      glow.addColorStop(1, "rgba(114,242,0,0)");
      ctx.fillStyle = glow;
      ctx.fillRect(0, 0, width, height);

      ctx.fillStyle = "rgba(255,255,255,0.03)";
      roundRect(ctx, 60, 60, width - 120, height - 120, 40, true, false);

      ctx.strokeStyle = "rgba(255,255,255,0.12)";
      ctx.lineWidth = 2;
      roundRect(ctx, 60, 60, width - 120, height - 120, 40, false, true);

      ctx.fillStyle = "#f1f3f6";
      ctx.textAlign = "center";
      ctx.font = "900 62px Inter, Arial";
      ctx.fillText("THE WARRIOR", width / 2, 150);

      ctx.fillStyle = "rgba(241,243,246,0.68)";
      ctx.font = "400 28px Inter, Arial";
      ctx.fillText("Walk Run Wrestle Proof Image", width / 2, 205);

      const routeX = 120;
      const routeY = 270;
      const routeW = width - 240;
      const routeH = 560;

      ctx.fillStyle = "rgba(255,255,255,0.03)";
      roundRect(ctx, routeX, routeY, routeW, routeH, 28, true, false);
      ctx.strokeStyle = "rgba(255,255,255,0.12)";
      ctx.lineWidth = 2;
      roundRect(ctx, routeX, routeY, routeW, routeH, 28, false, true);

      ctx.fillStyle = "rgba(241,243,246,0.68)";
      ctx.textAlign = "left";
      ctx.font = "700 24px Inter, Arial";
      ctx.fillText(session.method === "GPS" ? "PRIVATE RUN SHAPE" : "MANUAL ENTRY", routeX + 30, routeY + 45);

      if (session.method === "GPS" && Array.isArray(session.routePoints) && session.routePoints.length > 1){
        drawNormalizedRoute(ctx, session.routePoints, routeX + 40, routeY + 80, routeW - 80, routeH - 120);
      } else {
        ctx.textAlign = "center";
        ctx.fillStyle = "rgba(241,243,246,0.85)";
        ctx.font = "900 40px Inter, Arial";
        ctx.fillText("MANUAL RUN", width / 2, routeY + 230);

        ctx.fillStyle = "rgba(255,230,0,0.96)";
        ctx.font = "700 28px Inter, Arial";
        ctx.fillText("Additional proof required", width / 2, routeY + 290);

        ctx.fillStyle = "rgba(241,243,246,0.68)";
        ctx.font = "400 24px Inter, Arial";
        ctx.fillText("No GPS route is stored for manual entries.", width / 2, routeY + 355);
      }

      const statY = 900;
      drawStatBox(ctx, 120, statY, 280, 170, "DISTANCE", `${session.distanceKm.toFixed(2)} km`);
      drawStatBox(ctx, 460, statY, 280, 170, session.method === "GPS" ? "TIME" : "DATE", session.method === "GPS" ? session.timeText : new Date(session.date).toLocaleDateString());
      drawStatBox(ctx, 800, statY, 280, 170, "EST. STEPS", session.steps.toLocaleString());

      drawStatBox(ctx, 120, 1110, 450, 150, "METHOD", session.method === "GPS" ? "GPS TRACKED" : "MANUAL ENTRY");
      drawStatBox(ctx, 610, 1110, 470, 150, "DATE", new Date(session.date).toLocaleDateString());

      ctx.textAlign = "center";
      ctx.fillStyle = "rgba(241,243,246,0.68)";
      ctx.font = "400 24px Inter, Arial";
      const footerText = session.method === "GPS"
        ? "This image shows a private route shape only. No place names or map markers are included."
        : "Manual entry. Please provide extra supporting proof with your email.";
      wrapText(ctx, footerText, width / 2, 1360, 900, 34);

      ctx.fillStyle = "#4fd1d1";
      ctx.font = "900 24px Inter, Arial";
      ctx.fillText("WALK RUN WRESTLE", width / 2, 1490);

      const safeDate = new Date(session.date).toISOString().slice(0, 10);
      const uniqueId = `${Date.now()}-${Math.floor(Math.random() * 100000)}`;
      const filename = session.method === "GPS"
        ? `warrior-proof-gps-${safeDate}-${uniqueId}.png`
        : `warrior-proof-manual-${safeDate}-${uniqueId}.png`;

      const link = document.createElement("a");
      link.download = filename;
      link.href = canvas.toDataURL("image/png");
      link.click();

      sessions[index].proofDownloaded = true;
      saveSessions(sessions);
      renderSessions();
    }

    function drawNormalizedRoute(ctx, points, x, y, w, h){
      const xs = points.map(p => p[1]);
      const ys = points.map(p => p[0]);

      const minX = Math.min(...xs);
      const maxX = Math.max(...xs);
      const minY = Math.min(...ys);
      const maxY = Math.max(...ys);

      const rangeX = Math.max(maxX - minX, 0.00001);
      const rangeY = Math.max(maxY - minY, 0.00001);

      const pad = 30;
      const drawW = w - pad * 2;
      const drawH = h - pad * 2;

      const scale = Math.min(drawW / rangeX, drawH / rangeY);

      const normalized = points.map(p => {
        const nx = x + pad + ((p[1] - minX) * scale);
        const ny = y + pad + ((p[0] - minY) * scale);
        return [nx, ny];
      });

      const routeMinX = Math.min(...normalized.map(p => p[0]));
      const routeMaxX = Math.max(...normalized.map(p => p[0]));
      const routeMinY = Math.min(...normalized.map(p => p[1]));
      const routeMaxY = Math.max(...normalized.map(p => p[1]));

      const offsetX = x + (w - (routeMaxX - routeMinX)) / 2 - routeMinX;
      const offsetY = y + (h - (routeMaxY - routeMinY)) / 2 - routeMinY;

      const centered = normalized.map(p => [p[0] + offsetX, p[1] + offsetY]);

      ctx.beginPath();
      centered.forEach((p, i) => {
        if (i === 0) ctx.moveTo(p[0], p[1]);
        else ctx.lineTo(p[0], p[1]);
      });
      ctx.lineWidth = 20;
      ctx.strokeStyle = "rgba(79,209,209,0.16)";
      ctx.lineCap = "round";
      ctx.lineJoin = "round";
      ctx.stroke();

      ctx.beginPath();
      centered.forEach((p, i) => {
        if (i === 0) ctx.moveTo(p[0], p[1]);
        else ctx.lineTo(p[0], p[1]);
      });
      ctx.lineWidth = 8;
      ctx.strokeStyle = "#4fd1d1";
      ctx.lineCap = "round";
      ctx.lineJoin = "round";
      ctx.stroke();

      ctx.beginPath();
      ctx.arc(centered[0][0], centered[0][1], 10, 0, Math.PI * 2);
      ctx.fillStyle = "#72f200";
      ctx.fill();

      const end = centered[centered.length - 1];
      ctx.beginPath();
      ctx.arc(end[0], end[1], 10, 0, Math.PI * 2);
      ctx.fillStyle = "#ff00e5";
      ctx.fill();
    }

    function drawStatBox(ctx, x, y, w, h, label, value){
      ctx.fillStyle = "rgba(255,255,255,0.03)";
      roundRect(ctx, x, y, w, h, 24, true, false);
      ctx.strokeStyle = "rgba(255,255,255,0.12)";
      ctx.lineWidth = 2;
      roundRect(ctx, x, y, w, h, 24, false, true);

      ctx.textAlign = "center";
      ctx.fillStyle = "rgba(241,243,246,0.68)";
      ctx.font = "700 22px Inter, Arial";
      ctx.fillText(label, x + w / 2, y + 48);

      ctx.fillStyle = "#f1f3f6";
      ctx.font = "900 34px Inter, Arial";
      wrapText(ctx, String(value), x + w / 2, y + 105, w - 40, 38);
    }

    function roundRect(ctx, x, y, width, height, radius, fill, stroke) {
      let r = radius;
      if (width < 2 * r) r = width / 2;
      if (height < 2 * r) r = height / 2;
      ctx.beginPath();
      ctx.moveTo(x + r, y);
      ctx.arcTo(x + width, y, x + width, y + height, r);
      ctx.arcTo(x + width, y + height, x, y + height, r);
      ctx.arcTo(x, y + height, x, y, r);
      ctx.arcTo(x, y, x + width, y, r);
      ctx.closePath();
      if (fill) ctx.fill();
      if (stroke) ctx.stroke();
    }

    function wrapText(ctx, text, centerX, startY, maxWidth, lineHeight){
      const words = String(text).split(" ");
      let line = "";
      let y = startY;

      for (let n = 0; n < words.length; n++) {
        const testLine = line + words[n] + " ";
        const metrics = ctx.measureText(testLine);
        const testWidth = metrics.width;
        if (testWidth > maxWidth && n > 0) {
          ctx.fillText(line.trim(), centerX, y);
          line = words[n] + " ";
          y += lineHeight;
        } else {
          line = testLine;
        }
      }
      ctx.fillText(line.trim(), centerX, y);
    }

    function sendProofEmail(){
      const totalKm = getTotalKm().toFixed(2);
      const totalSteps = getTotalSteps().toLocaleString();
      const includesManual = hasManualRuns();

      const subject = encodeURIComponent("The Warrior - Completed");

      const bodyText = includesManual
        ? `Hi WRW,

I have completed The Warrior 21K.

Total saved distance: ${totalKm} km
Estimated steps: ${totalSteps}

This completion includes one or more manual runs.
I have attached supporting proof for all manual runs.
I have also attached downloaded GPS proof images where relevant.

Full name:
First line of address:

Thanks`
        : `Hi WRW,

I have completed The Warrior 21K.

Total saved distance: ${totalKm} km
Estimated steps: ${totalSteps}

My GPS-tracked runs have been recorded in the app.
I have attached my downloaded proof images.

Full name:
First line of address:

Thanks`;

      const body = encodeURIComponent(bodyText);
      window.location.href = `mailto:${WRW_EMAIL}?subject=${subject}&body=${body}`;
    }

    document.addEventListener("visibilitychange", async () => {
      if (document.visibilityState === "visible" && isTracking){
        trackingNotice.innerHTML = `Tracking usually continues in the background on most devices.<br>If you switched apps or locked your phone, just double-check your distance when you return.`;
        setStatus("Tracking in progress", "status-live");
        await requestWakeLock();
      }
    });

    loginBtn.addEventListener("click", () => {
      const code = loginCodeInput.value.trim().toUpperCase();

      if (code !== LOGIN_CODE){
        alert("Wrong code.");
        return;
      }

      loginScreen.classList.remove("active");
      appScreen.classList.add("active");

      initMap();
      renderSessions();
      updateOverallProgress();

      locationStatus.textContent = "Location must be enabled before you can start your run.";
      locationOverlay.classList.add("show");
      startBtn.disabled = true;
      endBtn.disabled = true;
      manualAddBtn.disabled = false;
      setStatus("Ready to track", "status-ready");
    });

    loginCodeInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter") loginBtn.click();
    });

    loginCodeInput.addEventListener("input", () => {
      loginCodeInput.value = loginCodeInput.value.toUpperCase();
    });

    enableLocationBtn.addEventListener("click", enableLocationFromPopup);
    startBtn.addEventListener("click", startRun);
    endBtn.addEventListener("click", endRun);
    manualAddBtn.addEventListener("click", addManualRun);
    viewCompletionBtn.addEventListener("click", showFinishPopup);

    manualToggle.addEventListener("click", () => {
      toggleSection(manualContent, manualToggleText);
    });

    savedRunsToggle.addEventListener("click", () => {
      toggleSection(savedRunsContent, savedRunsToggleText);
    });

    howItWorksBtn.addEventListener("click", () => {
      howItWorksOverlay.classList.add("show");
    });

    closeHowItWorksBtn.addEventListener("click", () => {
      howItWorksOverlay.classList.remove("show");
    });

    sendProofHelpToggle.addEventListener("click", () => {
      toggleSection(sendProofHelpContent, sendProofHelpToggleText);
    });

    downloadSelectedProofBtn.addEventListener("click", () => {
      const selected = proofRunSelect.value;
      if (selected === "") {
        alert("Select a saved run first.");
        return;
      }
      downloadProofForRun(Number(selected));
    });

    downloadAllProofsBtn.addEventListener("click", () => {
      const sessions = getSessions();
      if (!sessions.length) {
        alert("No saved runs found.");
        return;
      }

      sessions.forEach((_, index) => {
        setTimeout(() => {
          downloadProofForRun(index);
        }, index * 450);
      });
    });

    resetBtn.addEventListener("click", () => {
      if (isTracking){
        alert("End the current run before resetting progress.");
        return;
      }

      localStorage.removeItem(STORAGE_KEY);
      localStorage.removeItem(COMPLETE_KEY);

      renderSessions();
      updateOverallProgress();
      hideFinishPopup();
      resetLiveStats();

      manualDistanceInput.value = "";
      manualDateInput.value = "";
      trackingNotice.textContent = "Tracking usually continues in the background on most devices. If you leave the app or lock your phone, just double-check your distance when you return.";
      gpsReadyBox.textContent = "GPS ready. Most devices will keep tracking in the background.";
      setStatus("Ready to track", "status-ready");
    });

    logoutBtn.addEventListener("click", async () => {
      if (isTracking){
        alert("End the current run before logging out.");
        return;
      }

      await releaseWakeLock();
      loginCodeInput.value = "";
      appScreen.classList.remove("active");
      loginScreen.classList.add("active");
      locationOverlay.classList.remove("show");
      howItWorksOverlay.classList.remove("show");
    });

    proofBtn.addEventListener("click", sendProofEmail);
    closeFinishBtn.addEventListener("click", hideFinishPopup);

    window.downloadProofForRun = downloadProofForRun;

    if (manualDateInput) {
      manualDateInput.value = new Date().toISOString().split("T")[0];
    }

    renderSessions();
    updateOverallProgress();
    setStatus("Ready to track", "status-ready");
  </script>
</body>
</html>

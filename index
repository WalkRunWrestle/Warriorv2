<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>The Warrior 21K</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

  <style>
    :root{
      --bg:#0b0b0d;
      --panel:#15171b;
      --panel2:#111317;
      --border:#2a2e36;
      --text:#f1f3f6;
      --muted:rgba(241,243,246,.68);

      --aqua:#4fd1d1;
      --lime:#72f200;
      --yellow:#ffe600;
      --pink:#ff00e5;
      --blue:#1a2bff;

      --primary:var(--lime);
      --primary-dark:#57b600;
      --danger:var(--pink);
      --warning:var(--yellow);
    }

    *{box-sizing:border-box}

    body{
      margin:0;
      font-family:Inter, Arial, sans-serif;
      color:var(--text);
      background:
        radial-gradient(900px 500px at 8% 10%, rgba(79,209,209,.16), transparent 55%),
        radial-gradient(700px 420px at 92% 14%, rgba(255,0,229,.12), transparent 55%),
        radial-gradient(800px 500px at 50% 100%, rgba(114,242,0,.10), transparent 55%),
        linear-gradient(180deg, #0b0b0d, #060608);
    }

    .screen{
      min-height:100vh;
      display:none;
      padding:10px 10px 18px;
      justify-content:center;
      align-items:center;
    }

    .screen.active{display:flex}

    .card{
      width:min(96vw, 760px);
      background:rgba(255,255,255,.03);
      border:1px solid var(--border);
      border-radius:18px;
      padding:10px;
      box-shadow:0 18px 40px rgba(0,0,0,.35);
    }

    .login-card{
      width:min(94vw, 360px);
      text-align:center;
      padding:12px;
    }

    .logo{
      display:block;
      max-width:78px;
      width:100%;
      height:auto;
      margin:0 auto 4px;
    }

    .medal{
      display:block;
      max-width:120px;
      width:100%;
      height:auto;
      margin:8px auto 8px;
      border-radius:12px;
      border:1px solid var(--border);
      background:rgba(255,255,255,.02);
    }

    .medal-small{
      display:block;
      max-width:95px;
      width:100%;
      height:auto;
      margin:6px auto 10px;
      border-radius:12px;
      border:1px solid var(--border);
      background:rgba(255,255,255,.02);
    }

    h1,h2,h3,p{margin:0}

    .title{
      font-size:18px;
      font-weight:900;
      text-transform:uppercase;
      letter-spacing:.4px;
      text-align:center;
    }

    .sub{
      margin-top:4px;
      color:var(--muted);
      font-size:11px;
      text-align:center;
      line-height:1.3;
    }

    .input{
      width:100%;
      padding:10px 12px;
      border-radius:12px;
      border:1px solid var(--border);
      background:var(--panel2);
      color:var(--text);
      font-size:14px;
      margin-top:10px;
      outline:none;
    }

    .btn{
      border:none;
      border-radius:12px;
      padding:10px 12px;
      font-size:14px;
      font-weight:900;
      cursor:pointer;
      transition:transform .15s ease, filter .15s ease, opacity .15s ease;
      text-decoration:none;
      text-align:center;
      display:inline-block;
    }

    .btn:hover{
      transform:translateY(-1px);
      filter:brightness(1.05);
    }

    .btn:disabled,
    .btn.disabled{
      opacity:.5;
      cursor:not-allowed;
      transform:none;
      filter:none;
      pointer-events:none;
    }

    .btn-primary{
      background:linear-gradient(135deg, #57b600, var(--lime));
      color:#111;
      box-shadow:0 0 0 1px rgba(255,255,255,.04), 0 8px 24px rgba(114,242,0,.16);
    }

    .btn-primary:hover{
      background:linear-gradient(135deg, #4da400, #89ff1f);
    }

    .btn-secondary{
      background:rgba(79,209,209,.12);
      color:var(--text);
      border:1px solid rgba(79,209,209,.35);
    }

    .btn-danger{
      background:linear-gradient(135deg, #d100ba, var(--pink));
      color:#fff;
      box-shadow:0 0 0 1px rgba(255,255,255,.04), 0 8px 24px rgba(255,0,229,.14);
    }

    .btn-gold{
      background:linear-gradient(135deg, #ffd400, var(--yellow), #fff16b);
      color:#141418;
    }

    .btn-playlist{
      background:linear-gradient(135deg, #36c6ff, var(--aqua));
      color:#0b0b0d;
      border:1px solid rgba(79,209,209,.3);
      box-shadow:0 0 0 1px rgba(255,255,255,.04), 0 8px 20px rgba(79,209,209,.14);
    }

    .btn-certificate-coming{
      background:linear-gradient(135deg, #2a36ff, var(--blue));
      color:#fff;
      box-shadow:0 0 0 1px rgba(255,255,255,.04), 0 10px 24px rgba(26,43,255,.22);
    }

    .full{
      width:100%;
      margin-top:8px;
    }

    .app-wrap{
      width:min(96vw, 940px);
      display:flex;
      flex-direction:column;
      gap:8px;
    }

    .top-card{
      text-align:center;
      padding:10px;
    }

    .status-bar{
      margin-top:6px;
      padding:8px 10px;
      border-radius:12px;
      border:1px solid var(--border);
      background:rgba(255,255,255,.04);
      font-size:11px;
      font-weight:800;
      line-height:1.35;
    }

    .status-ready{ color:var(--aqua); }
    .status-live{ color:var(--yellow); }
    .status-saved{ color:#f1f3f6; }
    .status-complete{ color:var(--pink); }

    .progress-big{
      margin-top:6px;
      font-size:14px;
      font-weight:900;
      line-height:1.25;
    }

    .progress-bar{
      width:100%;
      height:8px;
      border-radius:999px;
      background:rgba(255,255,255,.08);
      border:1px solid var(--border);
      overflow:hidden;
      margin-top:8px;
    }

    .progress-fill{
      height:100%;
      width:0%;
      background:linear-gradient(90deg, var(--aqua), var(--lime), var(--pink));
      transition:width .25s ease;
    }

    .summary-strip{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:6px;
      margin-top:8px;
    }

    .summary-box{
      border:1px solid var(--border);
      background:rgba(255,255,255,.03);
      border-radius:12px;
      padding:8px 10px;
      text-align:left;
    }

    .summary-label{
      font-size:9px;
      color:var(--muted);
      font-weight:700;
      text-transform:uppercase;
      letter-spacing:.4px;
    }

    .summary-value{
      margin-top:3px;
      font-size:12px;
      font-weight:900;
      line-height:1.25;
    }

    .helper-links{
      display:flex;
      gap:6px;
      flex-wrap:wrap;
      justify-content:center;
      margin-top:8px;
    }

    .helper-link-btn{
      background:transparent;
      color:var(--text);
      border:1px solid var(--border);
      border-radius:999px;
      padding:7px 10px;
      font-size:11px;
      font-weight:800;
      cursor:pointer;
      text-decoration:none;
      display:inline-flex;
      align-items:center;
      justify-content:center;
    }

    .grid{
      display:grid;
      grid-template-columns:1fr;
      gap:8px;
    }

    @media (min-width:860px){
      .grid{grid-template-columns:1.1fr .9fr}
    }

    .stats{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:6px;
      margin-top:8px;
    }

    .stat{
      background:rgba(255,255,255,.03);
      border:1px solid var(--border);
      border-radius:12px;
      padding:8px 6px;
      text-align:center;
    }

    .stat-label{
      font-size:10px;
      color:var(--muted);
      font-weight:700;
      text-transform:uppercase;
      letter-spacing:.4px;
    }

    .stat-value{
      margin-top:2px;
      font-size:14px;
      font-weight:900;
      line-height:1.15;
    }

    #map{
      width:100%;
      height:170px;
      border-radius:12px;
      border:1px solid var(--border);
      overflow:hidden;
      margin-top:8px;
    }

    .row{
      display:flex;
      gap:6px;
      flex-wrap:wrap;
    }

    .row .btn{
      flex:1 1 140px;
      width:auto;
      margin-top:0;
    }

    .notice{
      margin-top:8px;
      padding:8px 10px;
      border-radius:12px;
      border:1px solid var(--border);
      background:rgba(255,255,255,.03);
      color:var(--muted);
      font-size:11px;
      line-height:1.4;
    }

    .gps-ready{
      margin-top:8px;
      padding:8px 10px;
      border-radius:12px;
      border:1px solid rgba(79,209,209,.25);
      background:rgba(79,209,209,.08);
      color:#c9ffff;
      font-size:11px;
      line-height:1.35;
      font-weight:700;
    }

    .section-title{
      font-size:14px;
      font-weight:900;
      margin-bottom:6px;
      text-transform:uppercase;
      letter-spacing:.25px;
    }

    .manual-box{
      margin-top:8px;
      padding:10px;
      border-radius:14px;
      border:1px solid var(--border);
      background:rgba(255,255,255,.03);
    }

    .manual-row{
      display:flex;
      gap:6px;
      flex-wrap:wrap;
      align-items:center;
      margin-top:6px;
    }

    .manual-row .input{
      flex:1 1 150px;
      margin-top:0;
    }

    .session-list{
      display:flex;
      flex-direction:column;
      gap:6px;
      margin-top:8px;
    }

    .session-item{
      border:1px solid var(--border);
      background:rgba(255,255,255,.03);
      border-radius:12px;
      padding:8px;
    }

    .session-top{
      display:flex;
      justify-content:space-between;
      gap:6px;
      align-items:center;
      flex-wrap:wrap;
      font-weight:800;
      font-size:12px;
    }

    .session-meta{
      margin-top:5px;
      color:var(--muted);
      font-size:11px;
      line-height:1.35;
    }

    .session-actions{
      display:flex;
      gap:6px;
      flex-wrap:wrap;
      margin-top:6px;
    }

    .session-badge{
      display:inline-block;
      margin-top:5px;
      padding:4px 8px;
      border-radius:999px;
      border:1px solid var(--border);
      background:rgba(255,255,255,.04);
      font-size:10px;
      font-weight:900;
    }

    .badge-manual{
      color:var(--yellow);
      border-color:rgba(255,230,0,.35);
      background:rgba(255,230,0,.08);
    }

    .badge-gps{
      color:var(--aqua);
      border-color:rgba(79,209,209,.25);
      background:rgba(79,209,209,.08);
    }

    .badge-proof{
      color:var(--pink);
      border-color:rgba(255,0,229,.3);
      background:rgba(255,0,229,.08);
      margin-left:5px;
    }

    .small-title{
      font-size:14px;
      font-weight:900;
      margin-bottom:6px;
    }

    .collapsible-header{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:8px;
      cursor:pointer;
      user-select:none;
    }

    .collapse-toggle{
      font-size:11px;
      color:var(--muted);
      font-weight:800;
      white-space:nowrap;
    }

    .collapse-content{
      display:none;
    }

    .collapse-content.open{
      display:block;
    }

    .overlay{
      position:fixed;
      inset:0;
      background:rgba(0,0,0,.82);
      display:none;
      justify-content:center;
      align-items:center;
      padding:12px;
      z-index:9999;
    }

    .overlay.show{display:flex}

    .modal-card{
      width:min(94vw, 520px);
      background:var(--panel);
      border:1px solid var(--border);
      border-radius:18px;
      padding:14px 12px;
      text-align:center;
      box-shadow:0 20px 60px rgba(0,0,0,.55);
      max-height:92vh;
      overflow:auto;
    }

    .modal-title{
      font-size:24px;
      font-weight:900;
      margin-bottom:6px;
    }

    .modal-copy{
      color:var(--muted);
      line-height:1.35;
      font-size:12px;
      margin-bottom:10px;
    }

    .modal-status{
      margin-top:8px;
      color:var(--muted);
      font-size:11px;
      line-height:1.35;
    }

    .pill{
      padding:7px 9px;
      border-radius:999px;
      border:1px solid var(--border);
      background:rgba(255,255,255,.04);
      font-size:11px;
      font-weight:800;
    }

    .footer-actions{
      margin-top:8px;
      display:flex;
      gap:6px;
      flex-wrap:wrap;
    }

    .footer-actions .btn{
      flex:1 1 130px;
      width:auto;
      margin-top:0;
      padding:10px 12px;
    }

    .certificate-row{
      margin-top:10px;
    }

    .certificate-row .btn{
      width:100%;
      padding:12px 14px;
      font-size:15px;
    }

    .help{
      margin-top:8px;
      color:var(--muted);
      font-size:10px;
      text-align:center;
      line-height:1.35;
    }

    .login-help{
      margin-top:8px;
      font-size:11px;
      color:var(--muted);
      line-height:1.3;
    }

    .login-help a{
      color:var(--text);
      text-decoration:none;
      font-weight:700;
    }

    select.input{
      appearance:none;
    }
  </style>
</head>
<body>

  <section id="loginScreen" class="screen active">
    <div class="card login-card">
      <img src="Logo.png" alt="Walk Run Wrestle" class="logo">
      <h1 class="title">The Warrior 21K</h1>
      <img src="Warrior medal.png" alt="The Warrior Medal" class="medal">
      <p class="sub">Enter your login code to continue.</p>

      <div class="notice" style="margin-top:8px;">
        Built to be simple. No accounts. No tracking. Just your run.
      </div>

      <input id="loginCode" class="input" type="text" placeholder="Login code" autocomplete="one-time-code">
      <button id="loginBtn" class="btn btn-primary full">Continue</button>

      <div class="login-help">
        Forgot the login code? Message us at
        <a href="mailto:Contact@walkrunwrestle.com">Contact@walkrunwrestle.com</a>
      </div>
    </div>
  </section>

  <section id="appScreen" class="screen">
    <div class="app-wrap">
      <div class="card top-card">
        <img src="Logo.png" alt="Walk Run Wrestle" class="logo">
        <h2 class="title">The Warrior 21K</h2>
        <p class="sub">Track your runs and save progress toward 21K.</p>

        <div id="statusBar" class="status-bar status-ready">Ready to track</div>

        <div class="progress-big">
          Total Saved Progress: <span id="savedTotalKm">0.00</span> / 21.00 km
        </div>

        <div class="progress-bar">
          <div id="progressFill" class="progress-fill"></div>
        </div>

        <div class="summary-strip">
          <div class="summary-box">
            <div class="summary-label">Runs Saved</div>
            <div class="summary-value" id="runsSavedCount">0 runs</div>
          </div>
          <div class="summary-box">
            <div class="summary-label">Last Saved Run</div>
            <div class="summary-value" id="lastSavedRun">No runs saved yet</div>
          </div>
        </div>

        <div class="helper-links">
          <button id="howItWorksBtn" class="helper-link-btn">How tracking works</button>
          <a class="helper-link-btn btn-playlist" href="https://open.spotify.com/playlist/3XpXjz1aM2hIuoMAGGEg82?si=VYpibs25TWSsOT3oijNvMw&pi=AiqKZKT1SOGRF" target="_blank" rel="noopener noreferrer">Official Playlist</a>
        </div>

        <div class="footer-actions" id="completionActions" style="display:none; margin-top:8px;">
          <button id="viewCompletionBtn" class="btn btn-gold">View Completion</button>
        </div>
      </div>

      <div class="grid">
        <div class="card">
          <div class="small-title">Live Run</div>

          <div class="gps-ready" id="gpsReadyBox">
            GPS ready. Most devices will keep tracking in the background.
          </div>

          <div class="stats">
            <div class="stat">
              <div class="stat-label">Distance</div>
              <div class="stat-value"><span id="liveDistance">0.00</span> km</div>
            </div>
            <div class="stat">
              <div class="stat-label">Time</div>
              <div class="stat-value" id="liveTime">00:00:00</div>
            </div>
            <div class="stat">
              <div class="stat-label">Est. Steps</div>
              <div class="stat-value" id="liveSteps">0</div>
            </div>
          </div>

          <div id="map"></div>

          <div class="row" style="margin-top:8px;">
            <button id="startBtn" class="btn btn-primary" disabled>Start Run</button>
            <button id="endBtn" class="btn btn-danger" disabled>End Run</button>
          </div>

          <div class="notice" id="trackingNotice">
            Tracking usually continues in the background on most devices.
            If you leave the app or lock your phone, just double-check your distance when you return.
          </div>

          <div class="manual-box">
            <div class="collapsible-header" id="manualToggle">
              <div class="section-title" style="margin:0;">Manual Entry</div>
              <div class="collapse-toggle" id="manualToggleText">Show</div>
            </div>

            <div id="manualContent" class="collapse-content">
              <div class="notice" style="margin-top:6px;">
                For treadmill, indoor sessions, or GPS issues. Manual runs need extra proof.
              </div>

              <div class="manual-row">
                <input id="manualDistance" class="input" type="number" step="0.01" min="0" placeholder="Distance in km">
                <input id="manualDate" class="input" type="date">
              </div>

              <div class="manual-row">
                <button id="manualAddBtn" class="btn btn-secondary">Save Manual Run</button>
              </div>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="collapsible-header" id="savedRunsToggle">
            <div class="small-title" style="margin:0;">Saved Runs</div>
            <div class="collapse-toggle" id="savedRunsToggleText">Show</div>
          </div>

          <div id="savedRunsContent" class="collapse-content">
            <div id="sessionList" class="session-list"></div>

            <div class="footer-actions">
              <button id="resetBtn" class="btn btn-secondary">Reset Progress</button>
              <button id="logoutBtn" class="btn btn-secondary">Log Out</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div id="locationOverlay" class="overlay">
    <div class="modal-card">
      <div class="modal-title">Enable Location</div>

      <div class="modal-copy">
        We need location access to track your run distance live on the map.
      </div>

      <div class="notice" style="margin-top:0; text-align:left;">
        <strong>Your location stays private.</strong><br><br>
        We do not see or store where you walk or run.<br>
        Your location stays on your device only.<br><br>
        This tracker is for you only.<br>
        The only data saved is:
        <ul style="margin-top:6px; padding-left:18px;">
          <li>Distance</li>
          <li>Time</li>
          <li>Estimated steps</li>
          <li>A simple line image of your run for proof</li>
        </ul>
      </div>

      <div class="notice" style="margin-top:8px; text-align:left;">
        This works best when the app stays open, but most phones will continue tracking in the background.
        If you switch apps or lock your phone, just double-check your distance when you return.
      </div>

      <div class="footer-actions">
        <button id="enableLocationBtn" class="btn btn-primary">Enable Location</button>
      </div>

      <div id="locationStatus" class="modal-status">
        Location must be enabled before you can start your run.
      </div>
    </div>
  </div>

  <div id="finishOverlay" class="overlay">
    <div class="modal-card">
      <div class="modal-title">Well Done!</div>
      <img src="Warrior medal.png" alt="The Warrior Medal" class="medal-small">
      <div class="modal-copy">
        You’ve completed <strong>The Warrior 21K</strong>.
      </div>

      <div class="footer-actions" style="justify-content:center;">
        <div class="pill">🏁 Total saved: <span id="finishTotal">0.00</span> km</div>
        <div class="pill">👟 Estimated steps: <span id="finishSteps">0</span></div>
      </div>

      <div id="finishMessage" class="notice" style="text-align:left;">
        Attach your proof before sending.
      </div>

      <div class="manual-box" style="margin-top:10px; text-align:left;">
        <div class="section-title">Download Run Proofs</div>

        <div class="manual-row">
          <select id="proofRunSelect" class="input" style="margin-top:0;">
            <option value="">Select a saved run</option>
          </select>
        </div>

        <div class="footer-actions" style="margin-top:8px;">
          <button id="downloadSelectedProofBtn" class="btn btn-secondary">Download Selected Proof</button>
          <button id="downloadAllProofsBtn" class="btn btn-secondary">Download All Proofs</button>
        </div>
      </div>

      <div class="certificate-row">
        <button id="certificateBtn" class="btn btn-certificate-coming disabled" disabled>
          Certificate Coming Soon
        </button>
      </div>

      <div class="manual-box" style="margin-top:10px; text-align:left;">
        <div class="collapsible-header" id="sendProofHelpToggle">
          <div class="section-title" style="margin:0;">Send Proof Help</div>
          <div class="collapse-toggle" id="sendProofHelpToggleText">Show</div>
        </div>

        <div id="sendProofHelpContent" class="collapse-content">
          <div class="notice" style="margin-top:6px;">
            <strong>Having trouble with the Send Proof button?</strong><br><br>
            If your email app does not open automatically, send your proof manually to
            <strong>Log@walkrunwrestle.com</strong>.<br><br>
            Please include your <strong>full name</strong>, <strong>first line of address</strong>, and <strong>all proof images</strong>.
          </div>
        </div>
      </div>

      <div class="footer-actions">
        <button id="proofBtn" class="btn btn-gold">Send Proof</button>
        <button id="closeFinishBtn" class="btn btn-secondary">Close</button>
      </div>

